<UserControl
    x:Class="ExtrabbitCode.Inventor.ModernUi.Demo.GalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="640" d:DesignWidth="780">

    <UserControl.Resources>
        <!-- Left-navigation item + list styling (demo-local; not part of the library). -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
            <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
            <Setter Property="FontSize" Value="{DynamicResource Font.Size.Normal}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Control}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Brush.Accent}" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource NavItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Brush.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0"
                Background="{DynamicResource Brush.Panel}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="12">
                <StackPanel DockPanel.Dock="Top" Margin="4,4,4,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image x:Name="LogoImage"
                                   Width="24" Height="24"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Style="{DynamicResource TitleTextStyle}"
                                       VerticalAlignment="Center"
                                       Text="Modern UI" />
                        </StackPanel>
                        <Button x:Name="ThemeToggleButton"
                                Grid.Column="1"
                                MinWidth="0"
                                Width="34"
                                Height="28"
                                Padding="0"
                                ToolTip="Switch theme"
                                Click="OnToggleTheme">
                            <TextBlock x:Name="ThemeToggleIcon"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="15" />
                        </Button>
                    </Grid>
                    <TextBlock x:Name="InfoText"
                               Style="{DynamicResource CaptionTextStyle}"
                               Margin="0,6,0,0" />
                    <TextBlock Text="Accent color"
                               Style="{DynamicResource CaptionTextStyle}"
                               Margin="0,12,0,4" />
                    <ComboBox x:Name="AccentPicker"
                              DisplayMemberPath="Name"
                              SelectionChanged="OnAccentChanged" />
                </StackPanel>

                <ListBox x:Name="NavList"
                         Style="{StaticResource NavListStyle}"
                         DisplayMemberPath="Name"
                         SelectionChanged="OnNavChanged" />
            </DockPanel>
        </Border>

        <!-- Right content -->
        <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="PageTitle"
                           Style="{DynamicResource TitleTextStyle}"
                           Margin="0,0,0,16" />
                <StackPanel x:Name="ContentHost" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

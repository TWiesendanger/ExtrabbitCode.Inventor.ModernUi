<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Shared button template: rounded surface, hover/pressed/disabled states. -->
    <Style x:Key="ModernButtonBase" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
        <!-- Flat like a standard Inventor dialog button: takes the dialog/window background color,
             with a thin foreground (white-in-dark) border. -->
        <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Foreground}" />
        <Setter Property="BorderThickness" Value="0.6" />
        <Setter Property="Padding" Value="{DynamicResource Padding.Control}" />
        <Setter Property="MinHeight" Value="{DynamicResource Size.ControlHeight}" />
        <Setter Property="MinWidth" Value="84" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Normal}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Glow layer behind the (opaque) button: its drop shadow shows only OUTWARD,
                             because the opaque Bd on top covers the inner half. Hidden until hover. -->
                        <Border x:Name="Glow"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Background="{TemplateBinding Background}"
                                Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#C8C8C8" ShadowDepth="0" BlurRadius="7" Opacity="0.9" />
                            </Border.Effect>
                        </Border>

                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource Radius.Control}"
                                UseLayoutRounding="False"
                                SnapsToDevicePixels="False">
                            <Grid>
                                <!-- Subtle foreground tint for the pressed state (theme-aware). -->
                                <Border x:Name="Highlight"
                                        CornerRadius="{DynamicResource Radius.Control}"
                                        Background="{DynamicResource Brush.Foreground}"
                                        Opacity="0" />
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover: outward light-gray glow only. -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Glow" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Glow" Property="Opacity" Value="1" />
                            <Setter TargetName="Highlight" Property="Opacity" Value="0.16" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit default button. -->
    <Style TargetType="Button" BasedOn="{StaticResource ModernButtonBase}" />

    <!-- Accent / primary button: Style="{DynamicResource AccentButton}". -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Danger / destructive button (delete, remove): Style="{DynamicResource DangerButton}". -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButtonBase}">
        <Setter Property="Background" Value="{DynamicResource Brush.Error}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Error}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Compact, borderless icon button for toolbar / in-cell actions (content is usually an icon
         glyph). No min size or chrome; a rounded highlight appears on hover/press.
         Use: Style="{DynamicResource IconButton}". -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Normal}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{DynamicResource Radius.Control}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.AccentMuted}" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

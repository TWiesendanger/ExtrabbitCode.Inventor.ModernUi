<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Badges: keyed styles applied to a standard ContentControl (no custom control, so two library
         versions still coexist). Set Content to the label/number.
         Standalone:   <ContentControl Style="{DynamicResource Badge}" Content="Draft" />
         Colored:      Style="{DynamicResource BadgeAccent}" / "{DynamicResource BadgeError}"
         Counter:      Style="{DynamicResource CounterBadge}" Content="3"  (overlay top-right of a button)
         Shield:       <ContentControl Style="{DynamicResource ShieldLabel}" Content="build" />
                       <ContentControl Style="{DynamicResource ShieldValue}" Content="passing" /> -->

    <!-- Base pill: neutral panel surface, small semibold text, fully rounded. -->
    <Style x:Key="Badge" TargetType="ContentControl">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Panel}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Small}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9" Padding="8,2" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent variant. -->
    <Style x:Key="BadgeAccent" TargetType="ContentControl" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>

    <!-- Error / danger variant. -->
    <Style x:Key="BadgeError" TargetType="ContentControl" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{DynamicResource Brush.Error}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>

    <!-- Counter bubble: circle for a single digit, pill for more. Overlay on a button by placing it
         in the same Grid with HorizontalAlignment=Right, VerticalAlignment=Top and a negative margin. -->
    <Style x:Key="CounterBadge" TargetType="ContentControl" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{DynamicResource Brush.Error}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9" MinWidth="18" Height="18" Padding="5,0"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Two-tone shield (GitHub style): a neutral left segment + colored right segment placed next
         to each other in a horizontal StackPanel. -->
    <Style x:Key="ShieldLabel" TargetType="ContentControl" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{DynamicResource Brush.Control}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="9,0,0,9" Padding="8,2" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShieldValue" TargetType="ContentControl" BasedOn="{StaticResource Badge}">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Foreground" Value="#FFFFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="0,9,9,0" Padding="8,2" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

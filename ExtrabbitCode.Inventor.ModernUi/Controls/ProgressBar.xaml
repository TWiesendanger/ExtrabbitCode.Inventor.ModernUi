<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Control}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Height" Value="8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <Grid x:Name="PART_Track" ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Indeterminate bar: an accent band sweeps left -> right and repeats. Uses animated gradient
         offsets (relative 0..1), so it scales to any width without a converter (which would need a
         clr-namespace reference and break version coexistence).
         Use: <ProgressBar Style="{DynamicResource IndeterminateBar}" /> -->
    <Style x:Key="IndeterminateBar" TargetType="ProgressBar">
        <Setter Property="Background" Value="{DynamicResource Brush.Control}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Height" Value="8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            ClipToBounds="True"
                            SnapsToDevicePixels="True">
                        <Border CornerRadius="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop x:Name="S1" Color="Transparent" Offset="-0.4" />
                                    <GradientStop x:Name="S2" Color="{DynamicResource Color.Accent}" Offset="-0.2" />
                                    <GradientStop x:Name="S3" Color="Transparent" Offset="0.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="S1" Storyboard.TargetProperty="Offset"
                                                     From="-0.4" To="1.0" Duration="0:0:1.1" />
                                    <DoubleAnimation Storyboard.TargetName="S2" Storyboard.TargetProperty="Offset"
                                                     From="-0.2" To="1.2" Duration="0:0:1.1" />
                                    <DoubleAnimation Storyboard.TargetName="S3" Storyboard.TargetProperty="Offset"
                                                     From="0.0" To="1.4" Duration="0:0:1.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

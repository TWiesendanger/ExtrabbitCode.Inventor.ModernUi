<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Loading indicators as keyed styles on the standard ProgressBar (no custom control, so two
         library versions still coexist). They animate themselves on load.
         Spinner:  <ProgressBar Style="{DynamicResource Spinner}" />   (resize via Width/Height)
         Dots:     <ProgressBar Style="{DynamicResource DotsLoader}" /> -->

    <!-- Circular spinner: a faint full ring + a rotating 270° accent arc. Scales with Width/Height. -->
    <Style x:Key="Spinner" TargetType="ProgressBar">
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Viewbox>
                        <Grid Width="50" Height="50" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="Rot" Angle="0" />
                            </Grid.RenderTransform>
                            <Ellipse Width="45" Height="45"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Stroke="{DynamicResource Brush.Border}" StrokeThickness="4" />
                            <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 25,2.5 A 22.5,22.5 0 1 1 2.5,25" />
                        </Grid>
                    </Viewbox>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Rot"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:0.9"
                                                     RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Three pulsing dots. -->
    <Style x:Key="DotsLoader" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="D1" Width="9" Height="9" Margin="3,0" Opacity="0.3" Fill="{TemplateBinding Foreground}" />
                        <Ellipse x:Name="D2" Width="9" Height="9" Margin="3,0" Opacity="0.3" Fill="{TemplateBinding Foreground}" />
                        <Ellipse x:Name="D3" Width="9" Height="9" Margin="3,0" Opacity="0.3" Fill="{TemplateBinding Foreground}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="D1" Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1" AutoReverse="True" Duration="0:0:0.5" BeginTime="0:0:0" />
                                    <DoubleAnimation Storyboard.TargetName="D2" Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1" AutoReverse="True" Duration="0:0:0.5" BeginTime="0:0:0.15" />
                                    <DoubleAnimation Storyboard.TargetName="D3" Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1" AutoReverse="True" Duration="0:0:0.5" BeginTime="0:0:0.3" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

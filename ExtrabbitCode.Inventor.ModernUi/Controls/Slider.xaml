<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Thin track with an accent-filled portion from the minimum to the thumb, a round thumb (white
         with an accent ring, accent-filled while hovered/dragged), and optional tick marks.
         Horizontal by default; a vertical template is swapped in via the Orientation trigger.
         Tick marks render when the consumer sets TickPlacement (+ TickFrequency or Ticks); snapping
         works via IsSnapToTickEnabled — all standard Slider features, now supported by the template. -->

    <Style x:Key="ModernSliderThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Width" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd"
                            Background="{DynamicResource Brush.Foreground}"
                            BorderBrush="{DynamicResource Brush.Accent}"
                            BorderThickness="1"
                            CornerRadius="7"
                            SnapsToDevicePixels="True" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled (accent) portion, minimum -> thumb. -->
    <Style x:Key="ModernSliderFill" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{DynamicResource Brush.Accent}" CornerRadius="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Empty portion — transparent so the base track shows through. -->
    <Style x:Key="ModernSliderEmpty" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="ModernHorizontalSlider" TargetType="Slider">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MinHeight="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TickBar x:Name="TopTick" Grid.Row="0" Placement="Top" Height="4" Margin="0,0,0,3"
                     Fill="{DynamicResource Brush.ForegroundMuted}"
                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                     Ticks="{TemplateBinding Ticks}" TickFrequency="{TemplateBinding TickFrequency}"
                     Visibility="Collapsed" SnapsToDevicePixels="True" />

            <Border Grid.Row="1" Height="4" CornerRadius="2" VerticalAlignment="Center"
                    Background="{DynamicResource Brush.Control}" />
            <Track x:Name="PART_Track" Grid.Row="1">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ModernSliderFill}" Command="Slider.DecreaseLarge"
                                  Height="4" VerticalAlignment="Center" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ModernSliderThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ModernSliderEmpty}" Command="Slider.IncreaseLarge" />
                </Track.IncreaseRepeatButton>
            </Track>

            <TickBar x:Name="BottomTick" Grid.Row="2" Placement="Bottom" Height="4" Margin="0,3,0,0"
                     Fill="{DynamicResource Brush.ForegroundMuted}"
                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                     Ticks="{TemplateBinding Ticks}" TickFrequency="{TemplateBinding TickFrequency}"
                     Visibility="Collapsed" SnapsToDevicePixels="True" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ModernVerticalSlider" TargetType="Slider">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="20" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TickBar x:Name="TopTick" Grid.Column="0" Placement="Left" Width="4" Margin="0,0,3,0"
                     IsDirectionReversed="True"
                     Fill="{DynamicResource Brush.ForegroundMuted}"
                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                     Ticks="{TemplateBinding Ticks}" TickFrequency="{TemplateBinding TickFrequency}"
                     Visibility="Collapsed" SnapsToDevicePixels="True" />

            <Border Grid.Column="1" Width="4" CornerRadius="2" HorizontalAlignment="Center"
                    Background="{DynamicResource Brush.Control}" />
            <Track x:Name="PART_Track" Grid.Column="1" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ModernSliderFill}" Command="Slider.DecreaseLarge"
                                  Width="4" HorizontalAlignment="Center" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ModernSliderThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ModernSliderEmpty}" Command="Slider.IncreaseLarge" />
                </Track.IncreaseRepeatButton>
            </Track>

            <TickBar x:Name="BottomTick" Grid.Column="2" Placement="Right" Width="4" Margin="3,0,0,0"
                     IsDirectionReversed="True"
                     Fill="{DynamicResource Brush.ForegroundMuted}"
                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                     Ticks="{TemplateBinding Ticks}" TickFrequency="{TemplateBinding TickFrequency}"
                     Visibility="Collapsed" SnapsToDevicePixels="True" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template" Value="{StaticResource ModernHorizontalSlider}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Template" Value="{StaticResource ModernVerticalSlider}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

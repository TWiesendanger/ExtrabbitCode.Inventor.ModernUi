<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Labeled, bordered group of fields — the classic Inventor dialog building block. Header sits
         above a rounded, outlined content region (vs. Card, which is a filled surface). -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family}" />
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Normal}" />
        <Setter Property="Padding" Value="{DynamicResource Padding.Card}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <DockPanel>
                        <ContentPresenter DockPanel.Dock="Top"
                                          ContentSource="Header"
                                          TextElement.Foreground="{DynamicResource Brush.ForegroundMuted}"
                                          TextElement.FontWeight="SemiBold"
                                          Margin="2,0,0,6"
                                          SnapsToDevicePixels="True" />
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Card}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
